{
    "version": 1,
    // resources not included in templates
    "resources": [
        {
            "resourceName": "relative/path/to/resource.png",
            "resourceType": "Texture"
        },
        {
            "resourceName": "relative/path/to/resource.wav",
            "resourceType": "Sound"
        }
    ],
    // list of all entities loaded in the scene in alphabetical order by entityName
    "entities": [
        {
            "entityName": "unique_name_1",
            "template": "template1.json"
        },
        {
            "entityName": "unique_name_2",
            "template": "template1.json"
        },
        {
            "entityName": "unique_name_2",
            "template": ""
        }
    ],
    // entity component definitions grouped by component in order to take advantage of ECS caching characteristic
    "components": [
        {
            "componentName": "componentName1",
            // list is sorted by entityName in alphabetical order
            "perEntityValues": [ 
                {
                    // example of using a template
                    "entityName": "unique_name_1", 
                    "values": {}
                },
                {
                    // example of using a template and overriding values for given component
                    "entityName": "unique_name_2",
                    "values": {
                        "fieldName1": {
                            "val": "unique_name_1"
                        },
                        "fieldName2": {
                            "val": 432
                        },
                        "fieldName3": {
                            "val": "testVal"
                        }
                        // component might have "fieldName4" but since we are not overriding it, will
                        // grab values from parent
                    }
                },
                {
                    // example of not using a template
                    "entityName": "unique_name_3",
                    "values": {
                        "entityName": {
                            "val": "unique_name_1",
                            "fieldType": "entity"
                        },
                        "valueName1": {
                            "val": 432,
                            "fieldType": "int"
                        },
                        "valueName2": {
                            "val": "testVal",
                            "fieldType": "string"
                        },
                        "resourceRef": {
                            "val": "relative/path/to/resource.wav",
                            "fieldType": "resource"
                        }
                    }
                }
            ]
        },
        {
            "componentName": "componentName2",
            "perEntityValues": [ 
                {
                    "entityName": "unique_name_3",
                    "values": {
                        "vectorName": {
                            "val": [
                                1,
                                2,
                                43
                            ],
                            "fieldType": "vector"
                        },
                        "resourceRef": {
                            "val": "relative/path/to/resource.png",
                            "fieldType": "resource"
                        }
                    }
                }
            ]
        }
    ]
}