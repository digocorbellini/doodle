{
    "version": 1,
    // resources not included in templates
    "resources": [
        {
            "ref": "relative/path/to/resource.png",
            "resourceType": "Texture"
        },
        {
            "ref": "relative/path/to/resource.wav",
            "resourceType": "Sound"
        }
    ],
    "entities": [
        {
            // example of using template
            "entityName": "unique_name_1",
            "template": "template1.json",
            "components": []
        },
        {
            // example of template but overriding a component's values
            "entityName": "unique_name_2",
            "template": "temp_dir/template2.json",
            "components": [
                {
                    "name": "componentName1",
                    "values": {
                        "fieldName1": {
                            "val": "unique_name_1"
                        },
                        "fieldName2": {
                            "val": 432
                        },
                        "fieldName3": {
                            "val": "testVal"
                        }
                    }
                }
            ]
        },
        {
            // example of not using a template and defining an entity
            "entityName": "unique_name_3",
            "template": null,
            "components": [
                {
                    "name": "componentName1",
                    "values": {
                        "entityName": {
                            "val": "unique_name_1",
                            "fieldType": "entity"
                        },
                        "valueName1": {
                            "val": 432,
                            "fieldType": "int"
                        },
                        "valueName2": {
                            "val": "testVal",
                            "fieldType": "string"
                        },
                        "resourceRef": {
                            "val": "relative/path/to/resource.wav",
                            "fieldType": "resource"
                        }
                    }
                },
                {
                    "name": "componentName2",
                    "values": {
                        "vectorName": {
                            "val": [
                                1,
                                2,
                                43
                            ],
                            "fieldType": "vector"
                        },
                        "resourceRef": {
                            "val": "relative/path/to/resource.png",
                            "fieldType": "resource"
                        }
                    }
                }
            ]
        }
    ]
}