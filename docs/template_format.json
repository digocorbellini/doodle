{
    "version": 1,
    "parentTemplate": "example_dir/template_parent.json",
    // resources included in this template (ignore parent resources)
    "resources": [
        {
            "resourceName": "relative/path/to/resource.png",
            "resourceType": "Texture"
        }
    ],
    "components": {
        "componentName1": {
            // example of taking all parent values for component
        },
        "componentName2": {
            // example of overriding parent component
            "values": {
                "valueName1": {
                    "val": 432
                },
                "valueName2": {
                    "val": "testVal"
                }
            }
        },
        "componentName3": {
            // example of adding component that parent does not have
            "values": {
                "vectorName": {
                    "val": [
                        1,
                        2
                    ],
                    "fieldType": "vector2"
                },
                "resourceHandleStringName": {
                    "val": "relative/path/to/resource.png",
                    "fieldType": "resource"
                }
            }
        }
    }
}