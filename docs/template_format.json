{
    "version": 1,
    "parentTemplate": "example_dir/template_parent.json",
    // resources not included in parent template
    "resources": {
        "relative/path/to/resource.png": {
            "resourceType": "Texture"
        }
    },
    "components": [
        {
            // example of overriding parent component
            "name": "componentName1",
            "values": {
                "valueName1": {
                    "val": 432,
                    "fieldType": "int"
                },
                "valueName2": {
                    "val": "testVal",
                    "fieldType": "string"
                }
            }
        },
        {
            // example of adding component that parent does not have
            "name": "componentName2",
            "values": {
                "vectorName": {
                    "val": [
                        1,
                        2
                    ],
                    "fieldType": "vector2"
                },
                "resourceHandleStringName": {
                    "val": "relative/path/to/resource.png",
                    "fieldType": "resource"
                }
            }
        }
    ]
}