{
    "version": 1,
    "parentTemplate": "example_dir/template_parent",
    // resources not included in parent template
    "resources": [
        {
            "name": "resource1",
            "resourceType": "Texture",
            "path": "relative/path/to/resource.png"
        }
    ],
    "components": [
        {
            // example of overriding parent component
            "name": "componentName1",
            "values": [
                {
                    "val": 432
                },
                {
                    "val": "testVal"
                }
            ]
        },
        {
            // example of adding component that parent does not have
            "name": "componentName2",
            "values": [
                {
                    "fieldName": "vectorName",
                    "val": [1, 2, 43],
                    "fieldType": "vector"
                },
                {
                    "fieldName": "resourceHandleStringName",
                    "val": "resource1",
                    "fieldType": "resource"
                }
            ]
        }
    ]
}